# ============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO PARA KALIN
# ============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. NUNCA compartas tu archivo .env ni lo subas a control de versiones
# 4. Usa variables de entorno en producción, nunca hardcodees credenciales
# ============================================================================

# ----------------------------------------------------------------------------
# MODO DE OPERACIÓN
# ----------------------------------------------------------------------------
# local = Desarrollo (usa Ollama local, gratis)
# cloud = Producción (usa OpenAI/Anthropic, requiere API keys)
KALIN_MODE=local

# ----------------------------------------------------------------------------
# OLLAMA (LOCAL - DESARROLLO)
# ----------------------------------------------------------------------------
# Instalación: https://ollama.ai
# Modelo recomendado: deepseek-coder (gratuito, funciona offline)
# NOTA: Usamos el mismo modelo para CÓDIGO y CHAT para optimizar RAM
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-coder

# ----------------------------------------------------------------------------
# OPENAI (CLOUD - PRODUCCIÓN)
# ----------------------------------------------------------------------------
# Obtén tu API key en: https://platform.openai.com/api-keys
# Costo aproximado: $0.03 por 1K tokens (GPT-4 turbo)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

# ----------------------------------------------------------------------------
# ANTHROPIC / CLAUDE (CLOUD - FALLBACK)
# ----------------------------------------------------------------------------
# Obtén tu API key en: https://console.anthropic.com/
# Costo aproximado: $0.015 por 1K tokens (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ----------------------------------------------------------------------------
# AZURE OPENAI (OPCIONAL)
# ----------------------------------------------------------------------------
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_DEPLOYMENT=gpt-4

# ----------------------------------------------------------------------------
# HUGGING FACE (OPCIONAL)
# ----------------------------------------------------------------------------
# Obtén tu API key en: https://huggingface.co/settings/tokens
HF_API_KEY=
HF_MODEL=meta-llama/Llama-2-7b-chat-hf

# ----------------------------------------------------------------------------
# GROQ (CLOUD - GRATIS, ULTRA-RÁPIDO) ⚡
# ----------------------------------------------------------------------------
# Obtén tu API key GRATIS en: https://console.groq.com/keys
# Velocidad: <1 segundo por respuesta
# Modelos: Llama 3.3 70B, Mixtral, Gemma
# NOTA: Puedes usar GROQ_API_KEY o GROK_API_KEY (ambos funcionan)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ----------------------------------------------------------------------------
# GOOGLE GEMINI (CLOUD - GRATIS CON LÍMITES) 🌟
# ----------------------------------------------------------------------------
# Obtén tu API key GRATIS en: https://makersuite.google.com/app/apikey
# Límite: 60 requests/min, 1500 requests/día
# Modelos: Gemini 1.5 Pro, Gemini 1.5 Flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ----------------------------------------------------------------------------
# MISTRAL AI (CLOUD - ECONÓMICO) 🎯
# ----------------------------------------------------------------------------
# Obtén tu API key en: https://console.mistral.ai/
# Costo: ~$0.002 por 1K tokens (muy barato)
# Crédito inicial: $2-5 gratis
# Modelos: Mistral Large, Mixtral, Codestral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ----------------------------------------------------------------------------
# XIAOMI MiMo (CLOUD - GRATUITO TEMPORALMENTE) 🚀
# ----------------------------------------------------------------------------
# Obtén tu API key GRATIS en: https://platform.xiaomimimo.com/
# Actualmente en fase de acceso gratuito
# Compatible con formato OpenAI API
# Modelos: mimo-v2-flash (rápido), mimo-v2-pro (avanzado)
MIMO_API_KEY=
MIMO_MODEL=mimo-v2-flash
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# ----------------------------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR FLASK
# ----------------------------------------------------------------------------
# ADVERTENCIA DE SEGURIDAD:
# - Usa 127.0.0.1 para desarrollo local (NO expongas a internet)
# - Usa 0.0.0.0 SOLO si estás detrás de un reverse proxy con autenticación
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=0  # 0 = production, 1 = development (NUNCA en producción)

# ----------------------------------------------------------------------------
# TASK QUEUE (CELERY + REDIS)
# ----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# NOTAS DE SEGURIDAD IMPORTANTES
# ----------------------------------------------------------------------------
# 1. NUNCA subas el archivo .env a GitHub/GitLab
# 2. Agrega .env a tu .gitignore
# 3. En producción, usa variables de entorno del sistema o vaults de secretos
# 4. Rota tus API keys regularmente
# 5. Si una API key se filtra, revócala inmediatamente y genera una nueva
# 
# Para verificar que tu configuración es segura, ejecuta:
# python -c "from agent.core.security_hardening import security_auditor; print(security_auditor.run_full_audit())"
# ----------------------------------------------------------------------------
